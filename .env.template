### COSMOS DB CONFIG ###

# Cosmos DB account endpoint. Authentication uses COSMOS_KEY when set, otherwise DefaultAzureCredential.
COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/

# Optional Cosmos DB account key. Leave blank to use DefaultAzureCredential / Entra ID.
COSMOS_KEY=

# Target Cosmos DB database name. The database must already exist.
COSMOS_DATABASE_NAME=<dbname>

# Target Cosmos DB container name. The container must already exist.
COSMOS_CONTAINER_NAME=<container>

# Source document field used as the Cosmos DB partition key value.
PARTITION_KEY_FIELD=docid


### DATA LOADING ###

# Remote source file downloaded by src/download_data.py.
DATA_URL=<data_url

# Local folder where src/download_data.py writes downloaded and optionally decompressed files.
DATA_DIR=./data

# Input mode. Use fake for generated documents or file for JSON/JSONL input.
DATA_TYPE=file

# Local JSON/JSONL input path. Paths ending in .bz2 are decompressed while reading.
DOC_JSON_PATH=./data/example.json

# JSON input shape. Supported values are jsonl, array, and multiple_values.
DOC_JSON_FORMAT=jsonl

# Number of prepared file documents sent per worker queue item.
READ_BATCH_SIZE=1000

# File-input document queue multiplier. Larger values buffer more documents from disk so inserts are less likely to wait on file loading, but consume more RAM.
DOC_QUEUE_MULTIPLIER=30


### SCENARIO AND PERFORMANCE ###

# Number of worker client processes used to upload documents.
NUM_CLIENTS=1

# Number of documents each worker pulls into a local bulk insert before scheduling uploads.
BULK_SIZE=30

# Optional upload cap. Leave blank for no cap when DATA_TYPE=file.
MAX_TOTAL_DOCS=

# Number of fake documents generated when DATA_TYPE=fake.
TOTAL_DOCS=1000000

# Approximate synthetic payload size in bytes when DATA_TYPE=fake.
PAYLOAD_BYTES=1000

# (.NET only) Length of the randomly generated `emb` embedding vector on each fake document (values in [-1, 1]).
FAKE_DATA_VECTOR_DIM=1536

# Maximum concurrent create_item calls per worker process.
MAX_CONCURRENCY=-1

# Maximum number of local bulks allowed in flight per worker before the scheduler waits.
MAX_PENDING_BULKS=8

# Number of quick retries for throttled or transient Cosmos write failures.
MAX_INSERT_RETRIES=3

# Base retry delay in milliseconds when Cosmos does not return retry-after guidance.
INSERT_RETRY_DELAY_MS=50


### METRICS AND DIAGNOSTICS ###

# Number of detailed Cosmos write failures to print per worker.
COSMOS_ERROR_SAMPLE_LIMIT=3

# Enables x-ms-request-charge capture through a per-request response hook. Disable to reduce hot-path overhead.
CAPTURE_RU_CHARGES=true

# (.NET only) Returns the written document body on each create. Keep false for faster writes; the RU charge is unaffected.
ENABLE_CONTENT_RESPONSE_ON_WRITE=false

# (.NET only) Stream raw record bytes and parse/prepare each document on the worker threads instead of the single producer
# (faster for large vector docs); set false to use the per-object write path.
USE_STREAM_WRITER=true

# Prints live create_item requests/sec by x-ms-partition-key-range-id when Cosmos returns that header.
PARTITION_KEY_RANGE_RPS_ENABLED=false

# Seconds between live metrics refreshes and periodic throughput samples.
METRICS_SAMPLE_INTERVAL_SEC=2.0

# Records one bulk timing sample every N completed local bulks. Higher values reduce metrics overhead.
METRICS_TIMING_SAMPLE_INTERVAL=1

# Warmup seconds excluded from Rally-style sampled throughput and timing summaries.
METRICS_WARMUP_SEC=0.0


### RESULTS ###

# Enables writing final metrics CSV files into TEST_RESULTS_ROOT.
CSV_OUTPUT_ENABLED=true

# Root folder for metrics CSV output.
TEST_RESULTS_ROOT=results